---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/"
    ? path === "/" || path.startsWith("/blog")
    : path.startsWith(href);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      [ <a href="/" class:list={[{ active: isActive("/") }]}>blog</a> | <a
        href="/projects"
        class:list={[{ active: isActive("/projects") }]}>projects</a
      > | <a href="/goodies" class:list={[{ active: isActive("/goodies") }]}
        >goodies</a
      > | <a href="/about" class:list={[{ active: isActive("/about") }]}
        >about</a
      > ]
    </nav>
    <slot />
  </body>
</html>

<style>
  nav {
    padding-bottom: 1.5rem;
    color: darkgrey;
  }
  .active {
    color: orange;
  }
</style>

<script>
  import Snd from "snd-lib";

  const snd = new Snd();

  snd.load(Snd.KITS.SND01).then(() => {
    document.querySelectorAll("nav a").forEach((link) => {
      link.addEventListener("mousedown", () => snd.play("tap_03"));
    });
  });
</script>
