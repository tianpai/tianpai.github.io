---
import Base from "../layouts/Base.astro";
---

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .header h1 {
    font-size: 1rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--text-heading);
    text-transform: uppercase;
  }
  .header p {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .section {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .row {
    padding: 0.35rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .row a {
    color: var(--text);
  }
  .row a:hover {
    color: var(--link-hover);
  }
</style>

<Base title="Tianpai" hideNav>
  <div class="home">
    <div class="header">
      <h1>Tianpai</h1>
      <p>developer</p>
    </div>

    <div class="section">
      <div class="row"><a href="/blog">blogs</a></div>
      <div class="row"><a href="/projects">projects</a></div>
      <div class="row"><a href="/goodies">goodies</a></div>
      <div class="row"><a href="/search">search</a></div>
      <div class="row"><a href="/about">about</a></div>
    </div>

    <div class="section">
      <div class="row">
        <a
          href="https://github.com/tianpai"
          target="_blank"
          rel="noopener noreferrer">github</a
        >
      </div>
    </div>
  </div>
</Base>

<script>
  import Snd from "snd-lib";

  const snd = new Snd();

  snd.load(Snd.KITS.SND01).then(() => {
    document.querySelectorAll(".home a").forEach((link) => {
      link.addEventListener("mousedown", () => snd.play("tap_03"));
    });
  });
</script>
