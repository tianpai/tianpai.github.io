---
import Base from "../layouts/Base.astro";
---

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .section {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .row {
    padding: 0.35rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>

<Base title="Tianpai" breadcrumbs={[{label: "tianpai", href: "/"}]}>
  <div class="home">

    <div class="section">
      <div class="row"><a href="/blog">blogs</a></div>
      <div class="row"><a href="/projects">projects</a></div>
      <div class="row"><a href="/goodies">goodies</a></div>
      <div class="row"><a href="/search">search</a></div>
      <div class="row"><a href="/about">about</a></div>
    </div>

    <div class="section">
      <div class="row">
        <a
          href="https://github.com/tianpai"
          target="_blank"
          rel="noopener noreferrer">github</a
        >
      </div>
    </div>
  </div>
</Base>

<script>
  import Snd from "snd-lib";

  const snd = new Snd();

  snd.load(Snd.KITS.SND01).then(() => {
    document.querySelectorAll(".home a").forEach((link) => {
      link.addEventListener("mousedown", () => snd.play("tap_03"));
    });
  });
</script>
