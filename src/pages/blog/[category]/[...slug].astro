---
import Base from "../../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { category: post.data.category, slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<style>
  article {
    padding-bottom: 6rem;
  }
  article :global(h1) {
    font-size: 1.7rem;
    color: lightgray;
  }
  article :global(h2),
  article :global(h3),
  article :global(h4),
  article :global(h5) {
    font-size: 1rem;
    font-weight: normal;
    margin-top: 1.6em;
    color: lightgray;
  }
  article :global(h2)::before {
    content: "## ";
  }
  article :global(h3)::before {
    content: "### ";
  }
  article :global(h4)::before {
    content: "#### ";
  }
  article :global(h5)::before {
    content: "##### ";
  }
  article :global(p) {
    text-align: justify;
    margin-top: 1.6em;
  }
  article :global(strong) {
    color: orange;
    font-style: italic;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.5em;
  }
  article :global(time) {
    font-style: italic;
    color: darkgrey;
  }
  article :global(ul),
  article :global(ol) {
    list-style-position: inside;
    margin-top: 0.4em;
  }
  article :global(li) :global(ul),
  article :global(li) :global(ol) {
    padding-left: 2em;
  }
  article :global(table) {
    margin-top: 1.6em;
    border-collapse: collapse;
    width: 100%;
    border: 1px solid #444;
  }
  article :global(th),
  article :global(td) {
    border: 1px solid #444;
    padding: 0.4em 0.8em;
    text-align: left;
  }
  article :global(th) {
    color: lightgray;
    border-bottom: 2px solid #666;
  }
  article :global(tr:nth-child(even)) {
    background: rgba(255, 255, 255, 0.02);
  }
  .meta ul {
    display: flex;
    list-style: none;
    gap: 0.5rem;
  }
  .meta li {
    color: gray;
    padding: 2px;
    font-size: 0.85em;
  }
  .bottom-bar {
    margin-top: 3rem;
    color: #666;
  }
  .bottom-bar a {
    color: #666;
    text-decoration: none;
  }
  .bottom-bar a:hover {
    color: #aaa;
  }
</style>

<Base title={post.data.title}>
  <article>
    <h1>{post.data.title}</h1>
    <div class="meta">
      <time>{post.data.date.toISOString().slice(0, 10)}</time>
      {
        post.data.tags && (
          <ul>
            {post.data.tags.map((tag: string) => (
              <li>[{tag}]</li>
            ))}
          </ul>
        )
      }
    </div>
    <Content />
    <div class="bottom-bar">
      [ <a href="#" id="top-btn">top</a> | <a href="#" id="copy-btn"
        >copy as markdown</a
      > ]
    </div>
    <script
      type="application/json"
      id="post-markdown"
      set:html={JSON.stringify(post.body)}
    />
  </article>
  <script>
    import Snd from "snd-lib";

    const snd = new Snd();
    snd.load(Snd.KITS.SND01);

    document.getElementById("top-btn")!.addEventListener("click", (e) => {
      e.preventDefault();
      const start = window.scrollY;
      const duration = 150;
      const startTime = performance.now();
      function step(now: number) {
        const t = Math.min((now - startTime) / duration, 1);
        const ease = t < 0.5 ? 2 * t * t : 1 - (-2 * t + 2) ** 2 / 2;
        window.scrollTo(0, start * (1 - ease));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    });

    document
      .getElementById("copy-btn")!
      .addEventListener("click", async (e) => {
        e.preventDefault();
        const md = JSON.parse(
          document.getElementById("post-markdown")!.textContent!,
        );
        await navigator.clipboard.writeText(md);
        snd.play("button");
        const btn = e.target as HTMLAnchorElement;
        btn.textContent = "copied as markdown";
        setTimeout(() => {
          btn.textContent = "copy as markdown";
        }, 3000);
      });
  </script>
</Base>
