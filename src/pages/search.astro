---
import Base from "../layouts/Base.astro";

const resultLimit = 10;
---

<Base title="Search">
  <section class="search-page" data-result-limit={String(resultLimit)}>
    <form class="search-form" role="search">
      <label class="sr-only" for="search-input">Search</label>
      <div class="search-bar">
        <span aria-hidden="true">[</span>
        <input
          id="search-input"
          class="search-input"
          type="search"
          autocomplete="off"
          autocapitalize="none"
          spellcheck="false"
          enterkeyhint="search"
        />
        <button
          id="search-clear"
          class="search-clear"
          type="button"
          aria-label="Clear search"
        >
          x
        </button>
        <span aria-hidden="true">]</span>
      </div>
    </form>

    <ul id="search-results" class="search-results"></ul>
    <p id="search-empty" class="search-empty" hidden>no results</p>
  </section>

  <script>
    type PagefindSearchResultData = {
      url: string;
      excerpt: string;
      meta?: {
        title?: string;
      };
    };

    type PagefindModule = {
      init(): Promise<void>;
      preload(term: string): void;
      debouncedSearch(term: string): Promise<{
        results: Array<{
          data(): Promise<PagefindSearchResultData>;
        }>;
      } | null>;
    };

    const searchPageElement =
      document.querySelector<HTMLElement>(".search-page");
    const inputElement =
      document.querySelector<HTMLInputElement>("#search-input");
    const clearButtonElement =
      document.querySelector<HTMLButtonElement>("#search-clear");
    const resultsElement =
      document.querySelector<HTMLUListElement>("#search-results");
    const emptyStateElement =
      document.querySelector<HTMLParagraphElement>("#search-empty");

    if (
      !searchPageElement ||
      !inputElement ||
      !clearButtonElement ||
      !resultsElement ||
      !emptyStateElement
    ) {
      throw new Error("Search page elements are missing.");
    }

    const searchPage = searchPageElement;
    const input = inputElement;
    const clearButton = clearButtonElement;
    const results = resultsElement;
    const emptyState = emptyStateElement;
    const resultLimit = Number(searchPage.dataset.resultLimit || "10");

    let pagefindPromise: Promise<PagefindModule> | undefined;
    let requestId = 0;

    function setClearVisibility() {
      clearButton.classList.toggle("visible", Boolean(input.value.trim()));
    }

    function setEmptyVisibility(visible: boolean) {
      emptyState.hidden = !visible;
    }

    function setIdleState() {
      results.replaceChildren();
      setEmptyVisibility(false);
      setClearVisibility();
    }

    async function initPagefind() {
      if (!pagefindPromise) {
        const pagefindPath = "/pagefind/pagefind.js";
        pagefindPromise = import(/* @vite-ignore */ pagefindPath).then(
          async function (pagefind: PagefindModule): Promise<PagefindModule> {
            await pagefind.init();
            return pagefind;
          },
        );
      }
      return pagefindPromise;
    }

    function createResult(data: PagefindSearchResultData): HTMLLIElement {
      const item = document.createElement("li");
      item.className = "search-result";

      const title = document.createElement("a");
      title.className = "search-result-title";
      title.href = data.url;
      title.textContent = data.meta?.title || data.url;

      const excerpt = document.createElement("p");
      excerpt.className = "search-result-excerpt";
      excerpt.innerHTML = data.excerpt;

      item.append(title, excerpt);
      return item;
    }

    async function runSearch() {
      requestId += 1;
      const activeRequest = requestId;
      const query = input.value.trim();

      setClearVisibility();

      if (!query) {
        setIdleState();
        return;
      }

      setEmptyVisibility(false);

      try {
        const pagefind = await initPagefind();
        const search = await pagefind.debouncedSearch(query);
        if (activeRequest !== requestId || search === null) {
          return;
        }
        const count = search.results.length;
        if (!count) {
          results.replaceChildren();
          setEmptyVisibility(true);
          return;
        }
        const data = await Promise.all(
          search.results.slice(0, resultLimit).map(function (result) {
            return result.data();
          }),
        );
        if (activeRequest !== requestId) {
          return;
        }
        const fragment = document.createDocumentFragment();
        data.forEach(function (result) {
          fragment.append(createResult(result));
        });
        results.replaceChildren(fragment);
        setEmptyVisibility(false);
      } catch {
        if (activeRequest !== requestId) {
          return;
        }
        results.replaceChildren();
        setEmptyVisibility(false);
      }
    }

    input.addEventListener(
      "focus",
      function () {
        initPagefind().catch(function () {});
      },
      { once: true },
    );

    input.addEventListener("input", function () {
      runSearch();
    });

    clearButton.addEventListener("click", function () {
      input.value = "";
      requestId += 1;
      setIdleState();
      input.focus();
    });

    setIdleState();
  </script>
</Base>

<style>
  .search-page {
    display: grid;
    gap: 1rem;
  }

  .search-form {
    width: 100%;
  }

  .search-bar {
    display: flex;
    align-items: center;
    width: 100%;
    color: var(--text);
  }

  .search-input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: 1rem;
    outline: none;
  }

  .search-input::-webkit-search-cancel-button {
    display: none;
  }

  .search-clear {
    width: 1ch;
    margin-left: 0;
    margin-right: 1ch;
    border: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: 1rem;
    opacity: 0;
    pointer-events: none;
    cursor: pointer;
  }

  .search-clear.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .search-results {
    list-style: none;
    display: grid;
    gap: 2.5rem;
  }

  .search-empty {
    color: var(--text-muted);
  }

  .search-result {
    display: grid;
    gap: 0.75rem;
  }

  .search-result-title {
    color: lightgrey;
    font-size: 1.2rem;
    font-weight: 700;
  }

  .search-result-title:hover {
    color: orange;
  }

  .search-result-excerpt {
    color: darkgrey;
    line-height: 1.6;
  }

  .search-results :global(mark) {
    background: orange !important;
    color: var(--bg) !important;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
